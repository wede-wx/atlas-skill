{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wede-wx/atlas-skill/atlas-goal-fidelity/goal-contract.schema.json",
  "title": "Atlas Goal Contract",
  "description": "A compact contract for preserving a user's original goal during AI agent execution.",
  "type": "object",
  "additionalProperties": false,
  "required": ["goal", "must_do", "must_not_do", "preserve"],
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 1,
      "description": "One short statement of the user-visible outcome."
    },
    "must_do": {
      "type": "array",
      "maxItems": 7,
      "items": {
        "$ref": "#/$defs/contract_item"
      }
    },
    "must_not_do": {
      "type": "array",
      "maxItems": 7,
      "items": {
        "$ref": "#/$defs/contract_item"
      }
    },
    "preserve": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/contract_item"
      }
    }
  },
  "$defs": {
    "contract_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "hard", "source_quote", "verify_by"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "hard": {
          "type": "boolean"
        },
        "source_quote": {
          "type": "string",
          "minLength": 1
        },
        "verify_by": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
